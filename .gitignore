# ==========================================
# 1. PYTHON VIRTUAL ENVIRONMENT (DO NOT PUSH)
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# 2. FRAMEWORK CACHES & COMPILED FILES
# ==========================================
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# ==========================================
# 3. SYSTEM & IDE JUNK
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==========================================
# 4. AI WEIGHT TRACKING CONFIGURATION
# ==========================================
# Step A: Globally ignore all model weight file types to prevent accident dumps
*.pt
*.pth
*.onnx
*.engine

# Step B: Force Git to track and push your explicit models directory
!models/
!models/*.pt
!models/*.pth