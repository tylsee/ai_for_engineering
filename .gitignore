# ==========================================
# 1. PYTHON VIRTUAL ENVIRONMENT (DO NOT PUSH)
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# 2. FRAMEWORK CACHES & COMPILED FILES
# ==========================================
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# ==========================================
# 3. SYSTEM & IDE JUNK
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==========================================
# 4. AI WEIGHT TRACKING CONFIGURATION
# ==========================================
# Step A: Globally ignore all model weight file types to prevent accident dumps
*.pt
*.pth
*.onnx
*.engine

# Step B: Force Git to track and push your explicit models directory
!models/
!models/*.pt
!models/*.pth

# ==========================================
# 5. LARGE DATA & GENERATED FILES
# ==========================================
# Emily's dataset (tracked separately, not in main repo)
data_emily/

# YOLO validation/training batch debug images (auto-generated, not needed)
runs/**/train_batch*.jpg
runs/**/val_batch*.jpg
runs/**/labels.jpg
runs/**/*.yaml

# YOLO validation outputs from notebook runs (auto-generated)
notebooks/runs/

# Label cache files
data/labels/*.cache
data/*/labels.cache